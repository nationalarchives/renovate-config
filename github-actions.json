{
  "packageRules": [
    {
      "description": "Internal reusable workflows — skip (intentionally follow @main)",
      "matchManagers": ["github-actions"],
      "matchPackageNames": ["/^nationalarchives\\//"],
      "enabled": false
    },
    {
      "description": "GitHub Actions — all updates (grouped, automerge)",
      "matchManagers": ["github-actions"],
      "matchUpdateTypes": ["minor", "patch", "pin", "digest", "major"],
      "pinDigests": true,
      "groupName": "Dependencies (all updates)",
      "semanticCommitType": "chore",
      "automerge": true,
      "minimumReleaseAge": "7 days"
    }
  ]
}
