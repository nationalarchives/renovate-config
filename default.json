{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    "github>nationalarchives/renovate-config:github-actions",
    "github>nationalarchives/renovate-config:internal-actions",
    "github>nationalarchives/renovate-config:python-packages",
    "github>nationalarchives/renovate-config:pre-commit",
    "github>nationalarchives/renovate-config:public-terraform-modules",
    "github>nationalarchives/renovate-config:internal-terraform-modules"
  ],
  "dependencyDashboard": true,
  "dependencyDashboardTitle": "Dependency Dashboard",
  "dependencyDashboardLabels": ["dependencies"],
  "labels": ["dependencies"],
  "platformAutomerge": true,
  "prHourlyLimit": 0,
  "osvVulnerabilityAlerts": true,
  "vulnerabilityAlerts": {
    "description": "Disabled — using osvVulnerabilityAlerts instead",
    "enabled": false
  }
}
